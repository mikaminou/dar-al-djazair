{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user",
        "professional"
      ],
      "default": "user",
      "description": "Permission role. 'user' = individual, 'professional' = real estate professional/agency"
    },
    "plan": {
      "type": "string",
      "enum": [
        "free",
        "premium"
      ],
      "default": "free",
      "description": "Subscription plan. 'free' = regular user, 'premium' = verified professional with listing rights"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "owner_full_name": {
      "type": "string",
      "description": "Full name of the owner/contact person for professional accounts"
    },
    "phone": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "agency_name": {
      "type": "string",
      "description": "Business/agency name for professional accounts"
    },
    "professional_type": {
      "type": "string",
      "enum": [
        "agence_immobiliere",
        "promoteur"
      ],
      "description": "Type of professional: real estate agency or property developer"
    },
    "years_of_experience": {
      "type": "number",
      "minimum": 0,
      "description": "Years of experience for professional accounts"
    },
    "wilaya": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string"
    },
    "is_verified": {
      "type": "boolean",
      "default": false,
      "description": "Set to true only after admin approval. Defaults to false."
    },
    "verification_type": {
      "type": "string",
      "enum": [
        "professional",
        "individual"
      ]
    },
    "lang": {
      "type": "string",
      "enum": [
        "fr",
        "en",
        "ar"
      ],
      "default": "fr",
      "description": "User's preferred language for notifications and UI"
    }
  },
  "required": [
    "first_name"
  ]
}