{
  "name": "NotificationPreference",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Email of the user"
    },
    "push_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether push notifications are enabled"
    },
    "sound_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether notification sound is enabled"
    }
  },
  "required": [
    "user_email"
  ]
}